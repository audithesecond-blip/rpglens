{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/analyser",  "dest": "/analyser.html" },
    { "src": "/converter", "dest": "/converter.html" },
    { "src": "/login",     "dest": "/login.html" },
    { "src": "/signup",    "dest": "/signup.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/",          "dest": "/index.html" } 
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
